# Copy these values into src/environments/environment.ts (and environment.prod.ts for production)
# Get Firebase config from: Firebase Console > Project Settings > General > Your apps

# Firebase Configuration
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# WhatsApp Business Number (for contact links)
WHATSAPP_NUMBER=+1234567890

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product images: products/{productId}/{filename}
    // Public read (customers can view product images)
    // Write only for authenticated admins with validation
    match /products/{productId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size <= 5 * 1024 * 1024  // 5 MB max
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)')
        && productId.matches('^[a-zA-Z0-9_-]+$')
        && filename.matches('^[a-zA-Z0-9._-]+\\.(jpg|jpeg|png|webp|gif)$');
    }
  }
}
